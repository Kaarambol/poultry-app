datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum FarmRole {
  OWNER
  MANAGER
  ASSISTANT_MANAGER
  VIEWER
}

enum TargetProfileScope {
  GLOBAL_TEMPLATE
  CROP
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  name     String?

  farmsCreated Farm[] @relation("FarmCreatedBy")

  farmUsers     FarmUser[]
  changeLogs    ChangeLog[]
  nightChecks   NightCheck[]
  forumTopics   ForumTopic[]       @relation("ForumTopicAuthor")
  forumPosts    ForumPost[]        @relation("ForumPostAuthor")
  forumLanguage UserForumLanguage?
}

model Farm {
  id   String @id @default(cuid())
  name String
  code String @unique

  createdByUserId String?
  createdBy       User?   @relation("FarmCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  feedContractor       String?
  chickenSupplier      String?
  feedPrice1           Float?
  feedPrice2           Float?
  feedPrice3           Float?
  feedPrice4           Float?
  feedPrice5           Float?
  wheatPrice           Float?
  chickenPrice         Float?
  liveWeightPricePerKg Float?

  farmNumber            String?
  chpCode               String?
  rodentControl         String?
  disinfectProgramme    String?
  waterSanitizer        String?
  footDipDisinfectant   String?
  cleaningContractor    String?
  vetContractor         String?
  electricianContractor String?
  generatorService      String?
  weedkiller            String?
  security              String?

  houses         House[]
  crops          Crop[]
  farmUsers      FarmUser[]
  changeLogs     ChangeLog[]
  feedRecords    FeedRecord[]
  nightChecks    NightCheck[]
  documents      FarmDocument[]
  targetProfiles TargetProfile[]
}

model House {
  id                       String  @id @default(cuid())
  farmId                   String
  name                     String
  code                     String?
  floorAreaM2              Float
  usableAreaM2             Float?
  defaultCapacityBirds     Int     @default(0)
  defaultDrinkerLineCount  Int     @default(0)
  defaultNippleCount       Int     @default(0)
  defaultFeederPanCount    Int     @default(0)
  defaultFanCount          Int     @default(0)
  defaultHeaterCount       Int     @default(0)
  defaultMinTempC          Float?
  defaultMaxTempC          Float?
  defaultTargetHumidityPct Float?
  defaultMaxCo2Ppm         Int?
  defaultMaxAmmoniaPpm     Float?
  notes                    String?

  farm        Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  placements  CropHousePlacement[]
  daily       DailyRecord[]
  cropConfigs CropHouseConfig[]
  feedRecords FeedRecord[]
  nightChecks NightCheck[]

  @@unique([farmId, code])
}

model Crop {
  id            String    @id @default(cuid())
  farmId        String
  cropNumber    String
  placementDate DateTime
  breed         String?
  hatchery      String?
  status        String    @default("ACTIVE")
  finishDate    DateTime?

  chickenPricePerKg   Float?
  salePricePerKgAllIn Float?
  currency            String? @default("GBP")

  finalBirdsSold   Int?
  finalAvgWeightKg Float?
  finalRevenueGbp  Float?
  finalNotes       String?

  notes String?

  openingFeedStockKg  Float? @default(0)
  openingWheatStockKg Float? @default(0)
  closingFeedStockKg  Float? @default(0)
  closingWheatStockKg Float? @default(0)

  farm             Farm                 @relation(fields: [farmId], references: [id], onDelete: Cascade)
  placements       CropHousePlacement[]
  daily            DailyRecord[]
  avaraExports     AvaraExport[]
  medications      MedicationRecord[]
  cropHouseConfigs CropHouseConfig[]
  feedRecords      FeedRecord[]
  nightChecks      NightCheck[]
  targetProfile    TargetProfile?

  @@unique([farmId, cropNumber])
}

model FeedRecord {
  id                    String   @id @default(cuid())
  farmId                String
  cropId                String
  houseId               String?
  date                  DateTime
  feedProduct           String
  feedKg                Float    @default(0)
  wheatKg               Float    @default(0)
  ticketNumber          String
  feedPricePerTonneGbp  Float?
  wheatPricePerTonneGbp Float?
  supplier              String?
  notes                 String?
  createdAt             DateTime @default(now())

  farm  Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop  Crop   @relation(fields: [cropId], references: [id], onDelete: Cascade)
  house House? @relation(fields: [houseId], references: [id], onDelete: SetNull)

  @@index([cropId])
  @@index([date])
}

model NightCheck {
  id              String   @id @default(cuid())
  farmId          String
  cropId          String
  houseId         String
  checkedByUserId String?
  date            DateTime
  checkTime       String?
  checkedByName   String?

  humidityPct Float?
  co2Ppm      Int?
  ammoniaPpm  Float?
  humidityOk  Boolean @default(false)
  co2Ok       Boolean @default(false)
  ammoniaOk   Boolean @default(false)

  litterScore Int?
  litterOk    Boolean @default(false)
  wetAreas    Boolean @default(false)
  capping     Boolean @default(false)
  litterNotes String?

  waterSystemOk Boolean @default(true)
  feedSystemOk  Boolean @default(true)
  ventilationOk Boolean @default(true)
  alarmOk       Boolean @default(true)
  generatorOk   Boolean @default(true)
  lightingOk    Boolean @default(true)

  birdsOk          Boolean @default(true)
  cropFillOk       Boolean @default(true)
  unusualBehaviour Boolean @default(false)

  windowsOpen       Boolean @default(false)
  fridgeTemp        Boolean @default(false)
  litterSampleTaken Boolean @default(false)

  fireExtinguisher      Boolean @default(false)
  footDipChange         Boolean @default(false)
  dosatronCheck         Boolean @default(false)
  vitaminAdd            Boolean @default(false)
  vaccination           Boolean @default(false)
  medication            Boolean @default(false)
  pestControlInspection Boolean @default(false)
  waterSanitizer        Boolean @default(false)

  calibrationWaterMeter    Boolean @default(false)
  calibrationTempProbe     Boolean @default(false)
  calibrationHumidityProbe Boolean @default(false)
  calibrationWeigher       Boolean @default(false)

  comments String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm          Farm  @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop          Crop  @relation(fields: [cropId], references: [id], onDelete: Cascade)
  house         House @relation(fields: [houseId], references: [id], onDelete: Cascade)
  checkedByUser User? @relation(fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@unique([cropId, houseId, date])
  @@index([farmId, date])
  @@index([cropId, date])
}

model FarmDocument {
  id               String    @id @default(cuid())
  farmId           String
  title            String
  documentType     String
  status           String    @default("ACTIVE")
  documentFormat   String    @default("ELECTRONIC")
  electronicCopy   Boolean   @default(true)
  officeCopy       Boolean   @default(false)
  gateHouseCopy    Boolean   @default(false)
  issueDate        DateTime?
  expiryDate       DateTime?
  nextReviewDate   DateTime?
  fileUrl          String?
  blobPath         String?
  originalFileName String?
  storedFileName   String?
  mimeType         String?
  referenceNo      String?
  issuer           String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId, status])
  @@index([farmId, documentType])
  @@index([expiryDate])
  @@index([nextReviewDate])
}

model CropHouseConfig {
  id                     String  @id @default(cuid())
  cropId                 String
  houseId                String
  activeFloorAreaM2      Float?
  activeCapacityBirds    Int?
  activeDrinkerLineCount Int?
  activeNippleCount      Int?
  activeFeederPanCount   Int?
  activeFanCount         Int?
  activeHeaterCount      Int?
  notes                  String?

  crop  Crop  @relation(fields: [cropId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([cropId, houseId])
}

model CropHousePlacement {
  id             String   @id @default(cuid())
  cropId         String
  houseId        String
  batchNo        Int      @default(1)
  placementDate  DateTime
  hatchery       String?
  flockNumber    String?
  birdsPlaced    Int
  parentAgeWeeks Int?

  thinDate  DateTime?
  thinBirds Int?

  thin2Date  DateTime?
  thin2Birds Int?

  clearDate  DateTime?
  clearBirds Int?

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  crop  Crop  @relation(fields: [cropId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([cropId, houseId, batchNo])
  @@index([cropId, houseId])
}

model DailyRecord {
  id      String   @id @default(cuid())
  cropId  String
  houseId String
  date    DateTime

  birdsTotal Int @default(0)
  mort       Int @default(0)

  cullsSmall Int @default(0)
  cullsLeg   Int @default(0)
  culls      Int @default(0)

  feedKg        Float  @default(0)
  waterL        Float  @default(0)
  avgWeightG    Float?
  weightPercent Float?

  temperatureMinC Float?
  temperatureMaxC Float?
  humidityMinPct  Float?
  humidityMaxPct  Float?
  co2MinPpm       Int?
  co2MaxPpm       Int?

  notes String?

  crop  Crop  @relation(fields: [cropId], references: [id], onDelete: Cascade)
  house House @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([cropId, houseId, date])
  @@index([houseId, date])
  @@index([cropId, date])
}

model AvaraExport {
  id        String   @id @default(cuid())
  cropId    String
  stage     String
  fileName  String
  filePath  String
  createdAt DateTime @default(now())

  crop Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)
}

model MedicationRecord {
  id                 String    @id @default(cuid())
  cropId             String
  startDate          DateTime
  medicineName       String
  supplier           String?
  batchNo            String?
  expireDate         DateTime?
  quantityPurchased  String?
  quantityUsed       String?
  animalIdentity     String?
  housesTreated      String?
  birdsTreated       Int?
  finishDate         DateTime?
  withdrawalPeriod   String?
  safeSlaughterDate  DateTime?
  administratorName  String?
  reasonForTreatment String?
  methodOfTreatment  String?
  dose               String?
  totalMgPcu         String?
  report             String?
  prescription       String?
  createdAt          DateTime  @default(now())

  crop Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)
}

model FarmUser {
  id     String   @id @default(cuid())
  farmId String
  userId String
  role   FarmRole @default(OWNER)

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([farmId, userId])
}

model ChangeLog {
  id          String   @id @default(cuid())
  farmId      String
  userId      String
  action      String
  description String
  createdAt   DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TargetProfile {
  id    String             @id @default(cuid())
  scope TargetProfileScope @default(GLOBAL_TEMPLATE)

  farmId String
  cropId String?

  name      String
  source    String? @default("ROSS_211")
  isDefault Boolean @default(false)

  humidityTargetPct Float? @default(55)
  co2TargetPpm      Int?   @default(3000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm Farm               @relation(fields: [farmId], references: [id], onDelete: Cascade)
  crop Crop?              @relation(fields: [cropId], references: [id], onDelete: Cascade)
  days TargetProfileDay[]

  @@unique([cropId])
  @@index([farmId, scope])
  @@index([cropId])
}

model ForumTopic {
  id         String   @id @default(cuid())
  title      String
  content    String
  authorId   String
  createdAt  DateTime @default(now())
  lastPostAt DateTime @default(now())

  author User        @relation("ForumTopicAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts  ForumPost[]

  @@index([lastPostAt])
}

model ForumPost {
  id        String   @id @default(cuid())
  topicId   String
  content   String
  authorId  String
  createdAt DateTime @default(now())

  topic  ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  author User       @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model UserForumLanguage {
  userId   String @id
  language String @default("en")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TargetProfileDay {
  id        String @id @default(cuid())
  profileId String
  dayNumber Int

  weightTargetG      Float?
  feedTargetG        Float?
  waterTargetMl      Float?
  temperatureTargetC Float?
  humidityTargetPct  Float?
  co2TargetPpm       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile TargetProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, dayNumber])
  @@index([dayNumber])
}
